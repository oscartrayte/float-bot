# ─────────────────────────────────────────
# FLOAT® Bot — Environment Variables
# Copy this file to .env and fill in your values
# ─────────────────────────────────────────

# Your bot token from discord.com/developers
DISCORD_TOKEN=your_bot_token_here

# Your application/client ID from discord.com/developers
CLIENT_ID=your_client_id_here

# The ID of the guild (server) you want to deploy commands to
GUILD_ID=your_guild_id_here

# The channel ID where newsletter posts should be sent
NEWSLETTER_CHANNEL_ID=your_newsletter_channel_id_here

# The channel ID where welcome messages should be sent
WELCOME_CHANNEL_ID=your_welcome_channel_id_here
